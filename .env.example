# Copy to .env for local dev, or set these as variables in Railway.

# Passcode that gates the host studio (#/host). CHANGE THIS before sharing the URL.
HOST_PASSCODE=change-me

# Optional — enables "Scan a printed menu photo". Your Anthropic API key.
# Without it, the app works fully; only menu scanning is disabled.
ANTHROPIC_API_KEY=

# Optional — model used for menu scanning (defaults to claude-opus-4-8).
# MENU_MODEL=claude-opus-4-8

# Optional — email (guest sign-in magic links + recap emails), via Resend (https://resend.com).
# Without these, the app runs fully; only email features are off (login shows a dev link).
RESEND_API_KEY=
FROM_EMAIL=Sake Journey <hello@yourdomain.com>

# Optional — public base URL used to build links inside emails. On Railway, set this to your
# generated domain (e.g. https://sake-journey.up.railway.app). If unset, it's derived per request.
# PUBLIC_URL=

# Optional — where to persist data/db.json. On Railway, point this at a
# mounted volume (e.g. /data) so guest data survives redeploys.
# DATA_DIR=/data

# Optional — Railway sets PORT automatically; only set locally to override 5178.
# PORT=5178
